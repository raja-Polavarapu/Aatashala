<script>
  function toggleMenu() {
    document.getElementById('hamburger').classList.toggle('open');
    document.getElementById('mobileMenu').classList.toggle('open');
  }
  function closeMenu() {
    document.getElementById('hamburger').classList.remove('open');
    document.getElementById('mobileMenu').classList.remove('open');
  }

  // Hero slideshow
  (function() {
    const slides = document.querySelectorAll('.hero-slide');
    let i = 0;
    setInterval(() => {
      slides[i].classList.remove('active');
      i = (i + 1) % slides.length;
      slides[i].classList.add('active');
    }, 4000);
  })();

  // Scroll fade-in
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('visible'); obs.unobserve(e.target); }});
  }, {threshold:0.1});
  document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));

  // Counter
  function animCount(el) {
    const t = parseInt(el.dataset.count), step = t/90;
    let n = 0;
    const id = setInterval(() => {
      n = Math.min(n+step, t);
      el.textContent = Math.floor(n)+'+';
      if(n>=t) clearInterval(id);
    },16);
  }
  const cobs = new IntersectionObserver(entries => {
    entries.forEach(e => { if(e.isIntersecting){ animCount(e.target); cobs.unobserve(e.target); }});
  },{threshold:0.5});
  document.querySelectorAll('[data-count]').forEach(el => cobs.observe(el));

  // Form
  const form = document.getElementById('contactForm');
  const btn = document.getElementById('submitBtn');
  form.addEventListener('submit', async e => {
    e.preventDefault();
    btn.disabled = true; btn.textContent = 'Sending...';
    if(form.action.includes('YOUR_FORM_ID')) {
      setTimeout(() => { form.style.display='none'; document.getElementById('formSuccess').style.display='block'; }, 700);
      return;
    }
    try {
      const res = await fetch(form.action, {method:'POST', body:new FormData(form), headers:{Accept:'application/json'}});
      if(res.ok) { form.style.display='none'; document.getElementById('formSuccess').style.display='block'; }
      else { btn.disabled=false; btn.textContent='🎯 Send My Request'; alert('Error. Call +91 90637 44404'); }
    } catch { btn.disabled=false; btn.textContent='🎯 Send My Request'; alert('Network error. Call +91 90637 44404'); }
  });
</script>
